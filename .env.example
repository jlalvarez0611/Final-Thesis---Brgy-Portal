# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Public site origin only (no /path or ?query). Example: https://your-app.vercel.app
# Production builds use this for password-reset and email redirects so links are never localhost.
# In Supabase → Authentication → URL Configuration: set Site URL to this origin and add Redirect URL
# https://your-app.vercel.app/auth?mode=login (plus your local dev URL if needed).
VITE_SITE_URL=http://localhost:5173