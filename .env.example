# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Site URL for auth redirects when running locally or in non-browser contexts.
# On a live HTTPS site, the app uses the current page URL (including GitHub Pages /repo/ path).
# You must still add the EXACT redirect URL in Supabase: Authentication → URL Configuration → Redirect URLs
# (e.g. https://YOUR_NAME.github.io/YOUR_REPO/auth?mode=login). If it is missing, Supabase falls back to "Site URL" (often localhost).
VITE_SITE_URL=http://localhost:5173