# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Public site origin only (no /path or ?query). Example: https://your-app.vercel.app
# On Vercel you can omit this if you use the default *.vercel.app host — the build uses VERCEL_URL automatically.
# REQUIRED in Supabase Dashboard → Authentication → URL Configuration:
#   - Site URL: https://your-app.vercel.app (NOT http://localhost:3000)
#   - Redirect URLs: add https://your-app.vercel.app/**  (wildcard) plus http://localhost:5173/** for local dev
# If redirect URLs do not match, Supabase sends users to Site URL (often still localhost) with ?code=...
VITE_SITE_URL=http://localhost:5173